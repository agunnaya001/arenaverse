# ============================================================================
# ArenaGameFi Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control

# ============================================================================
# NEXT.JS / APP CONFIG
# ============================================================================
NODE_ENV=production
NEXT_PUBLIC_APP_NAME=ArenaGameFi
NEXT_PUBLIC_APP_URL=https://arenagamefi.com

# ============================================================================
# SUPABASE DATABASE
# ============================================================================
# Get these from https://app.supabase.com/projects
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# BLOCKCHAIN / WEB3
# ============================================================================
# Base Network RPC
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# Smart Contract Addresses (deployed on Base)
NEXT_PUBLIC_ARENA_TOKEN_ADDRESS=0x3b855F88CB93aA642EaEB13F59987C552Fc614b5
NEXT_PUBLIC_ARENA_CHAMPION_ADDRESS=0x68f08b005b09B0F7D07E1c0B5CDe18E43CE2486A
NEXT_PUBLIC_ARENA_BATTLE_ADDRESS=0xF6fc2B6a306B626548ca9dF25B31a22D0f8971CF
NEXT_PUBLIC_ARENA_PVP_ADDRESS=0xd0C4Af12E95f9590e7314D079C58597771E57533
NEXT_PUBLIC_MARKETPLACE_ADDRESS=0x67817157Dd6E5945ac2fAf1a822e7f1dE26C698E

# Wallet Configuration
NEXT_PUBLIC_WALLET_CONNECT_ID=your-wallet-connect-project-id

# Admin Addresses (comma-separated)
NEXT_PUBLIC_ADMIN_ADDRESSES=0xAdminAddress1,0xAdminAddress2

# ============================================================================
# AI / LLM SERVICES
# ============================================================================
# For AI contract generation features
OPENAI_API_KEY=sk-your-key-here

# Or use Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ============================================================================
# AUTHENTICATION
# ============================================================================
# SIWE (Sign-In With Ethereum)
NEXT_PUBLIC_SIWE_DOMAIN=arenagamefi.com
NEXT_PUBLIC_SIWE_ORIGIN=https://arenagamefi.com

# JWT Secret for session tokens
JWT_SECRET=your-secure-random-string-32-chars-min

# ============================================================================
# RATE LIMITING
# ============================================================================
# Rate limit configuration (requests per minute)
RATE_LIMIT_BATTLE_START=10
RATE_LIMIT_API_GENERAL=30
RATE_LIMIT_AUTH=5

# ============================================================================
# ANALYTICS & MONITORING
# ============================================================================
# Vercel Analytics (automatic with Vercel deployment)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your-vercel-analytics-id

# Sentry for error tracking
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================================
# EMAIL / NOTIFICATIONS
# ============================================================================
# For transactional emails (optional)
SENDGRID_API_KEY=SG.your-key-here
SENDGRID_FROM_EMAIL=noreply@arenagamefi.com

# ============================================================================
# PAYMENTS / STRIPE (if implementing payments)
# ============================================================================
STRIPE_SECRET_KEY=sk_live_your-key-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-key-here

# ============================================================================
# CORS & SECURITY
# ============================================================================
ALLOWED_ORIGINS=https://arenagamefi.com,https://www.arenagamefi.com
CORS_CREDENTIALS=true

# ============================================================================
# FEATURES FLAGS
# ============================================================================
FEATURE_AI_STUDIO=true
FEATURE_LAUNCHPAD=true
FEATURE_AGENT_MARKETPLACE=true
FEATURE_GUILDS=true
FEATURE_TOURNAMENTS=true
FEATURE_STAKING=true

# ============================================================================
# MAINTENANCE / EMERGENCY
# ============================================================================
# Enable maintenance mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=We are performing scheduled maintenance. Please check back soon.

# Emergency admin mode
EMERGENCY_MODE=false

# ============================================================================
# NOTES
# ============================================================================
# - Never commit secrets to version control
# - Use Vercel environment variables for sensitive values
# - Rotate secrets regularly
# - Use different keys for staging and production
# - Enable 2FA for admin accounts
# - Monitor logs for suspicious activity
